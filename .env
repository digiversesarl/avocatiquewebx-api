APP_NAME=AvocatiqueWebX
APP_ENV=local
APP_KEY=base64:pV+LVqGkvkIieo6UK7Bprl5XenqFYSSVu3HMnOSk4gA=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

# Frontend (React / Vite)
FRONTEND_URL=http://localhost:8080

# ──────────────────────────────────────────────────────────────────────────
# Base de données — MySQL (Laragon)
# ──────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=avocatiquewebx
DB_USERNAME=root
DB_PASSWORD=

# ── Ou SQLite pour développement rapide ───────────────────────────────────
# DB_CONNECTION=sqlite
# DB_DATABASE=C:/laragon/www/avocatiquewebx-api/database/database.sqlite

# ──────────────────────────────────────────────────────────────────────────
# Session & Cache
# ──────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ──────────────────────────────────────────────────────────────────────────
# Mail (mot de passe oublié)
# ──────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@avocatiquewebx.ma"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────────────────────────────
# Sanctum
# ──────────────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,localhost:8000
SANCTUM_TOKEN_EXPIRATION=30

# ──────────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
